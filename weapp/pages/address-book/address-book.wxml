<view class="page">
  <!-- 选择模式提示 -->
  <view wx:if="{{selectMode}}" class="select-tip">点击地址即可填入收货信息</view>

  <!-- 空状态 -->
  <view wx:if="{{addresses.length === 0}}" class="empty-wrap">
    <view class="css-icon css-icon-lg icon-location" style="color:var(--color-text-tertiary)"></view>
    <text class="empty-text">暂无保存地址</text>
  </view>

  <!-- 地址列表 -->
  <view class="addr-list" wx:else>
    <view class="addr-card anim-slide-up" wx:for="{{addresses}}" wx:key="id" bindtap="selectAddress" data-idx="{{index}}">
      <view class="addr-main">
        <view class="addr-top">
          <text class="addr-name">{{item.name}}</text>
          <text class="addr-phone">{{item.phone}}</text>
          <view wx:if="{{item.isDefault}}" class="default-badge">默认</view>
        </view>
        <text class="addr-detail">{{item.address}}</text>
      </view>
      <view class="addr-actions" catchtap="stopProp">
        <text wx:if="{{!item.isDefault}}" class="action-link" bindtap="setDefault" data-idx="{{index}}">设为默认</text>
        <text class="action-link" bindtap="openEdit" data-idx="{{index}}">编辑</text>
        <text class="action-link action-del" bindtap="deleteAddress" data-idx="{{index}}">删除</text>
      </view>
    </view>
  </view>

  <!-- 新增按钮 -->
  <view class="add-btn-wrap">
    <button class="btn-add" bindtap="openAdd">+ 新增地址</button>
  </view>

  <!-- 表单弹窗遮罩 -->
  <view wx:if="{{showForm}}" class="form-mask" bindtap="closeForm"></view>

  <!-- 表单弹窗 -->
  <view class="form-popup {{showForm ? 'form-popup-show' : ''}}">
    <view class="form-handle"></view>
    <view class="form-title">{{editingId ? '编辑地址' : '新增地址'}}</view>
    <view class="form-body">
      <view class="field-row">
        <text class="field-label">姓名</text>
        <input class="field-input" placeholder="收货人姓名" value="{{form.name}}" data-field="name" bindinput="onInput"/>
      </view>
      <view class="divider"></view>
      <view class="field-row">
        <text class="field-label">手机号</text>
        <input class="field-input" placeholder="收货人手机号" type="number" value="{{form.phone}}" data-field="phone" bindinput="onInput" maxlength="11"/>
      </view>
      <view class="divider"></view>
      <view class="field-row">
        <text class="field-label">地址</text>
        <input class="field-input" placeholder="详细收货地址" value="{{form.address}}" data-field="address" bindinput="onInput"/>
      </view>
      <view class="divider"></view>
      <view class="field-row">
        <text class="field-label">设为默认</text>
        <switch checked="{{form.isDefault}}" bindchange="toggleDefault" color="var(--color-primary)"/>
      </view>
    </view>
    <view class="form-footer">
      <button class="btn-cancel" bindtap="closeForm">取消</button>
      <button class="btn-save" bindtap="saveAddress">保存</button>
    </view>
  </view>
</view>
