.page{background:var(--color-bg-page);min-height:100vh;padding:var(--space-lg)}.title{font-size:34rpx;font-weight:800;margin-bottom:var(--space-lg);color:var(--color-text-primary);text-align:center}.search-bar{display:flex;align-items:center;gap:16rpx;margin-bottom:var(--space-lg);background:var(--color-bg-card);border-radius:var(--radius-lg);padding:12rpx 24rpx;box-shadow:var(--shadow-sm)}.search-input{flex:1;font-size:var(--font-sm);color:var(--color-text-primary)}.search-btn{flex-shrink:0;font-size:var(--font-sm);padding:10rpx 28rpx;background:var(--color-primary);color:#fff;border-radius:var(--radius-md);margin:0;line-height:1.5;width:auto;min-width:0}.search-btn::after{border:none}.empty{display:flex;align-items:center;justify-content:center;min-height:40vh;color:var(--color-text-tertiary);font-size:var(--font-sm)}.swipe-wrapper{position:relative;overflow:hidden;margin-bottom:20rpx}.swipe-del{position:absolute;right:0;top:0;bottom:0;width:160rpx;background:#EF4444;color:#fff;display:flex;align-items:center;justify-content:center;font-size:28rpx;font-weight:700;border-radius:0 var(--radius-lg) var(--radius-lg) 0}.order-card{background:var(--color-bg-card);border-radius:var(--radius-lg);padding:var(--space-lg);margin-bottom:0;box-shadow:var(--shadow-md);border-left:6rpx solid transparent;transition:border-left-color 0.3s ease}.order-card-unpaid{border-left-color:var(--color-error)}.order-card-packing{border-left-color:var(--color-warning)}.order-card-shipping{border-left-color:var(--color-info)}.order-card-delivered{border-left-color:var(--color-success)}.order-hd{display:flex;justify-content:space-between;align-items:center;margin-bottom:var(--space-sm)}.order-id{font-size:var(--font-sm);font-weight:700;color:var(--color-text-primary)}.status-tag{display:inline-flex;align-items:center;font-size:var(--font-xs);font-weight:600;padding:6rpx 16rpx;border-radius:var(--radius-pill)}.unpaid{background:var(--color-error-bg);color:var(--color-error)}.packing{background:var(--color-warning-bg);color:var(--color-warning)}.shipping{background:var(--color-info-bg);color:var(--color-info)}.delivered{background:var(--color-success-bg);color:var(--color-success)}.order-addr{display:flex;align-items:center;margin-bottom:var(--space-sm)}.order-addr-text{font-size:var(--font-sm);color:var(--color-text-tertiary);flex:1}.order-items-list{margin-bottom:var(--space-sm)}.order-item-line{font-size:var(--font-sm);color:var(--color-text-secondary);display:block;line-height:1.8}.order-ft{display:flex;justify-content:space-between;align-items:center;border-top:1rpx solid var(--color-border);padding-top:var(--space-sm)}.order-total{font-size:var(--font-base);font-weight:800;color:var(--color-primary)}.order-time{font-size:var(--font-xs);color:var(--color-text-tertiary)}.btn-confirm{font-size:var(--font-xs);padding:8rpx 20rpx;background:var(--color-success);color:#fff;border-radius:var(--radius-pill);margin:0;line-height:1.5}