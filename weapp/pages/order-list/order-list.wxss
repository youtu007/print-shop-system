.page { background: #FFFBF5; min-height: 100vh; padding: 24rpx; }
.title { font-size: 34rpx; font-weight: 800; margin-bottom: 24rpx; color: #333; }
.empty { text-align: center; color: #bbb; font-size: 26rpx; padding: 80rpx 0; }
.order-card { background: #fff; border-radius: 20rpx; padding: 24rpx; margin-bottom: 20rpx; box-shadow: 0 4rpx 16rpx rgba(0,0,0,.06); }
.order-hd { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12rpx; }
.order-id { font-size: 26rpx; font-weight: 700; color: #333; }
.status-tag { font-size: 22rpx; font-weight: 600; padding: 4rpx 16rpx; border-radius: 99rpx; }
.unpaid   { background: #fef0f0; color: #e74c3c; }
.packing  { background: #fff3e0; color: #e67e22; }
.shipping { background: #e3f2fd; color: #2196f3; }
.delivered { background: #e8f9ec; color: #27ae60; }
.order-addr { font-size: 24rpx; color: #999; display: block; margin-bottom: 12rpx; }
.order-items-list { margin-bottom: 12rpx; }
.order-item-line { font-size: 24rpx; color: #555; display: block; line-height: 1.8; }
.order-ft { display: flex; justify-content: space-between; align-items: center; border-top: 1rpx solid #f5f5f5; padding-top: 12rpx; }
.order-total { font-size: 28rpx; font-weight: 800; color: #FF6B6B; }
.order-time { font-size: 22rpx; color: #bbb; }
