<view class="page">
  <view class="title">
    {{filter === 'unpaid' ? '待付款' : filter === 'packing' ? '待发货' : filter === 'shipping' ? '待收货' : '全部订单'}}
  </view>

  <view wx:if="{{loading}}" class="empty">加载中…</view>
  <view wx:elif="{{orders.length === 0}}" class="empty">暂无相关订单</view>

  <view class="order-card" wx:for="{{orders}}" wx:key="id">
    <view class="order-hd">
      <text class="order-id">订单 #{{item.shortId}}</text>
      <view class="status-tag {{item.statusCls}}">{{item.statusText}}</view>
    </view>
    <text class="order-addr">📍 {{item.address}}</text>
    <view class="order-items-list">
      <text class="order-item-line" wx:for="{{item.items}}" wx:key="id" wx:for-item="prod">{{prod.name}} × {{prod.qty}}</text>
    </view>
    <view class="order-ft">
      <text class="order-total">合计 ¥{{item.total_price}}</text>
      <text class="order-time">{{item.timeStr}}</text>
    </view>
  </view>
</view>
