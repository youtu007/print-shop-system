.page{background:#f7f7f7;min-height:100vh;padding-bottom:60rpx}

.header{background:#FF6B6B;padding:60rpx 40rpx 48rpx;display:flex;flex-direction:column;align-items:center}
.title{font-size:40rpx;font-weight:800;color:#fff;margin-bottom:12rpx}
.date{font-size:22rpx;color:rgba(255,255,255,0.75)}

.intro{background:#fff;margin:24rpx 24rpx 0;border-radius:16rpx;padding:32rpx}
.p{font-size:26rpx;color:#555;line-height:1.9}

.section{background:#fff;margin:16rpx 24rpx 0;border-radius:16rpx;overflow:hidden}
.section-title{display:flex;align-items:center;gap:16rpx;padding:28rpx 32rpx;border-bottom:1rpx solid #f0f0f0;font-size:28rpx;font-weight:700;color:#1a1a1a}
.section-num{background:#FF6B6B;color:#fff;font-size:20rpx;font-weight:800;width:40rpx;height:40rpx;border-radius:10rpx;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.section-body{padding:24rpx 32rpx 28rpx}

.item-row{display:flex;align-items:flex-start;gap:12rpx;margin-bottom:16rpx}
.item-row:last-child{margin-bottom:0}
.dot{font-size:28rpx;color:#FF6B6B;font-weight:700;flex-shrink:0;margin-top:2rpx}
.item-text{font-size:26rpx;color:#555;line-height:1.8;flex:1}
.warn-row{background:#FFF5F5;border-radius:10rpx;padding:16rpx;margin-top:8rpx}
.warn{color:#FF4444;font-size:26rpx}

.footer{text-align:center;padding:48rpx 0 20rpx}
.footer-text{font-size:24rpx;color:#bbb}
