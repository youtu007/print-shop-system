.page{background:var(--color-bg-page);min-height:100vh;padding:0}.profile-header{background:linear-gradient(135deg,#FF6B6B,#FF8A8A);padding:var(--space-2xl) var(--space-lg) var(--space-xl);display:flex;flex-direction:column;align-items:center;justify-content:center;border-radius:0 0 var(--radius-lg) var(--radius-lg);margin-bottom:var(--space-lg)}.profile-avatar{width:80rpx;height:80rpx;border-radius:50%;background:rgba(255,255,255,0.25);display:flex;align-items:center;justify-content:center;margin-bottom:var(--space-sm)}.profile-title{font-size:var(--font-xl);font-weight:800;color:var(--color-text-white)}.card{background:var(--color-bg-card);border-radius:var(--radius-md);padding:28rpx;margin:0 var(--space-lg) 20rpx;box-shadow:var(--shadow-md)}.card-hd{display:flex;justify-content:space-between;align-items:center;margin-bottom:28rpx}.card-title{font-size:var(--font-md);font-weight:700;color:var(--color-text-primary)}.card-more{font-size:var(--font-sm);color:var(--color-text-tertiary);display:flex;align-items:center;gap:var(--space-xs)}.order-types{display:flex;justify-content:space-around}.order-type{display:flex;flex-direction:column;align-items:center;gap:10rpx}.type-icon-wrap{position:relative}.badge{position:absolute;top:-8rpx;right:-12rpx;background:var(--color-primary);color:var(--color-text-white);font-size:18rpx;font-weight:700;min-width:32rpx;height:32rpx;border-radius:var(--radius-pill);display:flex;align-items:center;justify-content:center;padding:0 6rpx}.type-label{font-size:var(--font-sm);color:var(--color-text-secondary)}.cart-card{display:flex;align-items:center;gap:var(--space-md);border-left:6rpx solid var(--color-primary)}.cart-text{font-size:var(--font-base);font-weight:600;color:var(--color-text-primary);flex:1}.cart-count{font-size:var(--font-sm);color:var(--color-primary);font-weight:700}.cart-empty{font-size:var(--font-sm);color:var(--color-text-tertiary)}.css-arrow{display:inline-block;width:16rpx;height:16rpx;border-right:3rpx solid var(--color-text-tertiary);border-bottom:3rpx solid var(--color-text-tertiary);transform:rotate(-45deg);flex-shrink:0}.admin-entry{margin-top:var(--space-lg);padding-bottom:var(--space-2xl)}.admin-entry-btn{background:var(--color-bg-card);border:none;padding:0;margin:0 var(--space-lg);border-radius:var(--radius-md);box-shadow:var(--shadow-md)}.admin-entry-btn::after{border:none}.admin-entry-content{display:flex;align-items:center;gap:var(--space-md);padding:28rpx}.admin-entry-text{flex:1;font-size:var(--font-base);font-weight:600;color:var(--color-text-primary)}
.profile-info{display:flex;flex-direction:column;align-items:center;gap:4rpx}
.profile-phone{font-size:var(--font-lg);font-weight:700;color:#fff}
.profile-name{font-size:var(--font-sm);color:rgba(255,255,255,0.8)}
.logout-btn{margin-top:var(--space-sm);font-size:var(--font-sm);color:rgba(255,255,255,0.7);border:1rpx solid rgba(255,255,255,0.4);border-radius:var(--radius-pill);padding:6rpx 24rpx}
.login-prompt{background:var(--color-bg-card);border-radius:var(--radius-md);padding:var(--space-2xl) var(--space-lg);margin:0 var(--space-lg) 20rpx;box-shadow:var(--shadow-md);display:flex;flex-direction:column;align-items:center;gap:var(--space-lg)}
.login-prompt-text{font-size:var(--font-sm);color:var(--color-text-tertiary);text-align:center}
.btn-go-login{background:linear-gradient(135deg,var(--color-primary),var(--color-primary-light));color:#fff;border:none;border-radius:var(--radius-md);padding:20rpx 64rpx;font-size:var(--font-base);font-weight:700;box-shadow:0 4rpx 12rpx rgba(255,107,107,0.3)}
.btn-go-login::after{border:none}
.addr-card{display:flex;align-items:center;gap:var(--space-md);border-left:6rpx solid var(--color-primary)}