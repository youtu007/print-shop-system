.page { background: #FFFBF5; min-height: 100vh; padding: 24rpx; }
.title { font-size: 36rpx; font-weight: 800; margin-bottom: 24rpx; }

/* 卡片通用 */
.card { background: #fff; border-radius: 20rpx; padding: 28rpx; margin-bottom: 20rpx; box-shadow: 0 4rpx 16rpx rgba(0,0,0,.06); }
.card-hd { display: flex; justify-content: space-between; align-items: center; margin-bottom: 28rpx; }
.card-title { font-size: 30rpx; font-weight: 700; color: #333; }
.card-more { font-size: 24rpx; color: #bbb; }

/* 订单状态图标行 */
.order-types { display: flex; justify-content: space-around; }
.order-type { display: flex; flex-direction: column; align-items: center; gap: 10rpx; }
.type-icon-wrap { position: relative; }
.type-icon { font-size: 52rpx; }
.badge { position: absolute; top: -8rpx; right: -12rpx; background: #FF6B6B; color: #fff; font-size: 18rpx; font-weight: 700; min-width: 32rpx; height: 32rpx; border-radius: 99rpx; display: flex; align-items: center; justify-content: center; padding: 0 6rpx; }
.type-label { font-size: 24rpx; color: #555; }

/* 购物车卡片 */
.cart-card { display: flex; align-items: center; gap: 16rpx; }
.cart-icon { font-size: 40rpx; }
.cart-text { font-size: 28rpx; font-weight: 600; color: #333; flex: 1; }
.cart-count { font-size: 24rpx; color: #FF6B6B; font-weight: 700; }
.cart-empty { font-size: 24rpx; color: #bbb; }
.arrow { font-size: 28rpx; color: #ccc; }

/* 管理员入口 */
.admin-entry-btn { background: #fff; color: #bbb; border: 2rpx solid #e0e0e0; border-radius: 16rpx; padding: 22rpx; font-size: 26rpx; width: 100%; margin-top: 8rpx; }
