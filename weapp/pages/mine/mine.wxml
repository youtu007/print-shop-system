<view class="page">
  <!-- 顶部头部 -->
  <view class="profile-header">
    <view class="profile-avatar">
      <view class="css-icon css-icon-lg icon-user" style="color:#fff"></view>
    </view>
    <view wx:if="{{isLoggedIn}}" class="profile-info">
      <text class="profile-phone">{{userPhone}}</text>
      <text wx:if="{{userName}}" class="profile-name">{{userName}}</text>
    </view>
    <text wx:else class="profile-title">我的</text>
    <view wx:if="{{isLoggedIn}}" class="logout-btn" bindtap="doLogout">退出</view>
  </view>

  <!-- 未登录状态 -->
  <view wx:if="{{!isLoggedIn}}" class="login-prompt anim-slide-up">
    <text class="login-prompt-text">登录后查看订单、购物车及地址簿</text>
    <button class="btn-go-login" bindtap="goLogin">立即登录</button>
  </view>

  <!-- 已登录：订单卡片 -->
  <view wx:if="{{isLoggedIn}}" class="card anim-slide-up anim-delay-1">
    <view class="card-hd">
      <text class="card-title">我的订单</text>
      <text class="card-more" bindtap="goAllOrders">全部订单 <text class="css-arrow"></text></text>
    </view>
    <view class="order-types">
      <view class="order-type" bindtap="goOrders" data-status="packing">
        <view class="type-icon-wrap">
          <view class="icon-circle-wrap icon-circle-sm"><view class="css-icon css-icon-sm icon-package"></view></view>
          <view wx:if="{{counts.packing > 0}}" class="badge">{{counts.packing}}</view>
        </view>
        <text class="type-label">待发货</text>
      </view>
      <view class="order-type" bindtap="goOrders" data-status="shipping">
        <view class="type-icon-wrap">
          <view class="icon-circle-wrap icon-circle-sm"><view class="css-icon css-icon-sm icon-truck"></view></view>
          <view wx:if="{{counts.shipping > 0}}" class="badge">{{counts.shipping}}</view>
        </view>
        <text class="type-label">配送中</text>
      </view>
      <view class="order-type" bindtap="goOrders" data-status="delivered">
        <view class="type-icon-wrap">
          <view class="icon-circle-wrap icon-circle-sm"><view class="css-icon css-icon-sm icon-package"></view></view>
          <view wx:if="{{counts.delivered > 0}}" class="badge">{{counts.delivered}}</view>
        </view>
        <text class="type-label">已收货</text>
      </view>
    </view>
  </view>

  <!-- 已登录：购物车 -->
  <view wx:if="{{isLoggedIn}}" class="card cart-card anim-slide-up anim-delay-2" bindtap="goCart">
    <view class="css-icon css-icon-md icon-cart" style="color:var(--color-primary)"></view>
    <text class="cart-text">查看购物车</text>
    <text wx:if="{{cartCount > 0}}" class="cart-count">{{cartCount}} 件</text>
    <text wx:else class="cart-empty">暂无商品</text>
    <view class="css-arrow"></view>
  </view>

  <!-- 已登录：地址簿 -->
  <view wx:if="{{isLoggedIn}}" class="card addr-card anim-slide-up anim-delay-3" bindtap="goAddressBook">
    <view class="css-icon css-icon-md icon-location" style="color:var(--color-primary)"></view>
    <text class="cart-text">地址簿</text>
    <text class="cart-empty">管理收货地址</text>
    <view class="css-arrow"></view>
  </view>

  <!-- 管理员入口（始终显示） -->
  <view class="admin-entry anim-slide-up anim-delay-4">
    <button class="admin-entry-btn" bindtap="goAdminLogin">
      <view class="admin-entry-content">
        <view class="css-icon css-icon-md icon-lock" style="color:var(--color-warning)"></view>
        <text class="admin-entry-text">管理员入口</text>
        <view class="css-arrow"></view>
      </view>
    </button>
  </view>
</view>
