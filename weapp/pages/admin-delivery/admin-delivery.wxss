.page {
  min-height: 100vh;
  background: var(--color-bg-page);
  padding: var(--space-lg);
}

.tab-bar {
  display: flex;
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: 8rpx;
  margin-bottom: var(--space-lg);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: var(--space-md);
  border-radius: var(--radius-md);
  font-size: var(--font-base);
  font-weight: 600;
  color: var(--color-text-secondary);
  position: relative;
}

.tab-item.active {
  background: var(--color-primary);
  color: #fff;
}

.tab-count {
  position: absolute;
  top: 8rpx;
  right: 20rpx;
  background: var(--color-error);
  color: #fff;
  font-size: 20rpx;
  min-width: 32rpx;
  height: 32rpx;
  border-radius: var(--radius-pill);
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading, .empty-tip {
  text-align: center;
  padding: 120rpx;
  color: var(--color-text-tertiary);
}

.order-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}

.order-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: var(--space-lg);
  box-shadow: var(--shadow-sm);
}

.order-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: var(--space-sm);
}

.order-id {
  font-family: monospace;
  font-size: var(--font-sm);
  color: var(--color-primary);
  font-weight: 600;
}

.order-time {
  font-size: var(--font-xs);
  color: var(--color-text-tertiary);
}

.order-customer {
  font-weight: 600;
  font-size: var(--font-base);
  margin-bottom: var(--space-sm);
}

.order-items {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  margin-bottom: var(--space-sm);
}

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.order-total {
  font-weight: 700;
  font-size: var(--font-lg);
  color: var(--color-primary);
}

.btn-action {
  background: var(--color-primary);
  color: #fff;
  border: none;
  padding: 12rpx 24rpx;
  border-radius: var(--radius-md);
  font-size: var(--font-sm);
  font-weight: 600;
}
