.page { background: #FFFBF5; min-height: 100vh; padding: 24rpx; }
.title { font-size: 36rpx; font-weight: 800; margin-bottom: 32rpx; }
.login-box { background: #fff; border-radius: 24rpx; padding: 32rpx; box-shadow: 0 4rpx 16rpx rgba(0,0,0,.06); }
.input-wrap { background: #f8f8f8; border-radius: 12rpx; padding: 20rpx 24rpx; margin-bottom: 16rpx; }
.input-inner { width: 100%; font-size: 28rpx; color: #333; }
.btn { background: #FF6B6B; color: #fff; border-radius: 16rpx; padding: 24rpx; font-size: 30rpx; font-weight: 700; border: none; width: 100%; margin-top: 8rpx; }
.error { color: #e74c3c; font-size: 24rpx; display: block; margin-bottom: 12rpx; }
.hint { color: #bbb; font-size: 22rpx; text-align: center; display: block; margin-top: 16rpx; }
.welcome { font-size: 32rpx; font-weight: 700; display: block; margin-bottom: 24rpx; }
.nav-btn { background: #fff; color: #FF6B6B; border-radius: 16rpx; padding: 20rpx; font-size: 28rpx; font-weight: 600; border: 2rpx solid #FF6B6B; width: 100%; margin-bottom: 16rpx; }
.logout-btn { background: #f5f5f5; color: #333; border-radius: 16rpx; padding: 20rpx; font-size: 28rpx; border: none; width: 100%; }
