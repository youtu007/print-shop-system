.page{min-height:100vh;background:#fff;display:flex;flex-direction:column;justify-content:center;align-items:center;padding:var(--space-2xl)}
.content{width:100%;display:flex;flex-direction:column;align-items:center}
.logo-wrap{display:flex;flex-direction:column;align-items:center;margin-bottom:80rpx}
.logo-circle{width:120rpx;height:120rpx;border-radius:28rpx;background:linear-gradient(135deg,var(--color-primary),var(--color-primary-light));display:flex;align-items:center;justify-content:center;box-shadow:0 8rpx 24rpx rgba(255,107,107,0.35);margin-bottom:var(--space-lg)}
.app-name{font-size:var(--font-2xl);font-weight:800;color:var(--color-text-primary);margin-bottom:var(--space-sm)}
.app-sub{font-size:var(--font-sm);color:var(--color-text-tertiary)}
.btn-wrap{width:100%;margin-bottom:var(--space-xl)}
.btn-phone{width:100%;border:none;border-radius:var(--radius-xl);padding:32rpx;font-size:var(--font-md);font-weight:700;color:#fff;background:#07C160;box-shadow:0 4rpx 20rpx rgba(7,193,96,0.35)}
.btn-phone::after{border:none}
.btn-loading{opacity:0.7}
.privacy-tip{font-size:var(--font-xs);color:var(--color-text-tertiary);text-align:center;line-height:1.6;padding:0 var(--space-2xl)}
.agree-row{display:flex;align-items:center;justify-content:center;flex-wrap:wrap;margin-bottom:var(--space-lg);gap:4rpx}
.agree-box{width:36rpx;height:36rpx;border-radius:8rpx;border:2rpx solid #ccc;display:flex;align-items:center;justify-content:center;margin-right:8rpx;flex-shrink:0}
.agree-box-checked{background:var(--color-primary);border-color:var(--color-primary)}
.agree-tick{color:#fff;font-size:24rpx;line-height:1}
.agree-text{font-size:24rpx;color:var(--color-text-secondary)}
.agree-link{font-size:24rpx;color:var(--color-primary)}
.btn-disabled{opacity:0.45}
