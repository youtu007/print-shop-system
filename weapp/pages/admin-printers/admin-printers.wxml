<view class="page">
  <view class="page-header">
    <text class="page-title">打印机管理</text>
    <button wx:if="{{role === 'super'}}" class="btn-add" bindtap="addPrinter">+ 添加</button>
  </view>

  <view wx:if="{{loading}}" class="loading">加载中...</view>
  <view wx:elif="{{printers.length === 0}}" class="empty-tip">暂无打印机</view>

  <view class="printer-list">
    <view class="printer-card" wx:for="{{printers}}" wx:key="id">
      <view class="printer-header">
        <view class="printer-status">
          <view class="pulse-dot {{item.status}}"></view>
          <text class="status-text">{{item.status === 'online' ? '在线' : item.status === 'busy' ? '忙碌' : '离线'}}</text>
        </view>
        <view wx:if="{{role === 'super'}}" class="printer-actions">
          <text class="action-btn" bindtap="toggleStatus" data-idx="{{index}}">{{item.status === 'online' ? '关机' : '开机'}}</text>
          <text class="action-btn delete" bindtap="deletePrinter" data-idx="{{index}}">删除</text>
        </view>
      </view>
      <view class="printer-name">{{item.name}}</view>
      <view class="printer-location">{{item.location}}</view>
      <view class="printer-paper">
        <view class="paper-label">
          <text>纸张剩余</text>
          <text>{{item.paper_remaining}}%</text>
        </view>
        <view class="paper-bar">
          <view class="paper-fill" style="width: {{item.paper_remaining}}%"></view>
        </view>
      </view>
      <view wx:if="{{role === 'super'}}" class="printer-footer">
        <text class="action-btn" bindtap="updatePaper" data-idx="{{index}}">更新纸量</text>
      </view>
    </view>
  </view>
</view>
