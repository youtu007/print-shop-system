<view class="page"><view wx:if="{{items.length === 0}}" class="empty"><view class="empty-icon-wrap"><view class="css-icon css-icon-lg icon-cart" style="color:var(--color-primary)"></view></view><text class="empty-text">购物车空空如也</text><button class="go-shop-btn btn-primary-g" bindtap="goShop">去逛逛</button></view><view wx:else><view class="list"><view class="item-row" wx:for="{{items}}" wx:key="id"><view class="checkbox {{item.checked ? 'checked' : ''}}" bindtap="toggleCheck" data-index="{{index}}"><view wx:if="{{item.checked}}" class="check-mark">✓</view></view><view class="item-body"><text class="item-name">{{item.name}}</text><view wx:if="{{item.file_info}}" class="item-file-tag"><text>📄 {{item.file_info.file_name}} · {{item.file_info.page_count}}张</text></view><text class="item-price">¥{{item.price}}</text><view class="item-bottom"><view class="qty-row"><button class="qty-btn" hover-class="qty-btn-active" bindtap="decrease" data-index="{{index}}">-</button><text class="qty-num">{{item.qty}}</text><button class="qty-btn" hover-class="qty-btn-active" bindtap="increase" data-index="{{index}}">+</button></view><text class="item-subtotal">¥{{item.subtotal}}</text></view></view><view class="delete-btn" bindtap="deleteItem" data-index="{{index}}">×</view></view></view><view class="select-all-row"><view class="checkbox {{allChecked ? 'checked' : ''}}" bindtap="toggleAll"><view wx:if="{{allChecked}}" class="check-mark">✓</view></view><text class="select-all-text">全选</text></view></view><view wx:if="{{items.length > 0}}" class="footer"><view class="footer-info"><text class="selected-label">已选 {{selectedCount}} 件</text><view class="total-row"><text class="total-label">合计：</text><text class="total-price">¥{{totalPrice}}</text></view></view><button class="checkout-btn {{selectedCount === 0 ? 'disabled' : ''}}" bindtap="goCheckout">去下单</button></view></view>