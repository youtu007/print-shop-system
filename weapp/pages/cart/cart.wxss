.page { background: #FFFBF5; min-height: 100vh; padding: 24rpx 24rpx 160rpx; }

/* 空状态 */
.empty { display: flex; flex-direction: column; align-items: center; padding: 120rpx 0; gap: 20rpx; }
.empty-icon { font-size: 100rpx; }
.empty-text { font-size: 28rpx; color: #bbb; }
.go-shop-btn { background: #FF6B6B; color: #fff; border-radius: 99rpx; padding: 18rpx 60rpx; font-size: 28rpx; font-weight: 700; border: none; margin-top: 16rpx; }

/* 商品列表 */
.list { background: #fff; border-radius: 20rpx; overflow: hidden; box-shadow: 0 4rpx 16rpx rgba(0,0,0,.06); margin-bottom: 16rpx; }
.item-row { display: flex; align-items: flex-start; padding: 28rpx 24rpx; border-bottom: 1rpx solid #f5f5f5; gap: 20rpx; }
.item-row:last-child { border-bottom: none; }

/* 复选框 */
.checkbox { width: 44rpx; height: 44rpx; border-radius: 99rpx; border: 3rpx solid #ddd; display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 6rpx; box-sizing: border-box; }
.checkbox.checked { background: #FF6B6B; border-color: #FF6B6B; }
.check-mark { font-size: 24rpx; color: #fff; font-weight: 700; line-height: 1; }

/* 商品详情 */
.item-body { flex: 1; }
.item-name { font-size: 28rpx; font-weight: 700; color: #333; display: block; margin-bottom: 8rpx; }
.item-price { font-size: 24rpx; color: #999; display: block; margin-bottom: 16rpx; }
.item-bottom { display: flex; justify-content: space-between; align-items: center; }
.qty-row { display: flex; align-items: center; gap: 16rpx; }
.qty-btn { background: #f5f5f5; color: #333; border-radius: 99rpx; width: 52rpx; height: 52rpx; font-size: 30rpx; line-height: 52rpx; text-align: center; border: none; padding: 0; }
.qty-num { font-size: 28rpx; font-weight: 700; min-width: 32rpx; text-align: center; }
.item-subtotal { font-size: 28rpx; font-weight: 800; color: #FF6B6B; }

/* 删除 */
.delete-btn { font-size: 36rpx; color: #ccc; padding: 0 4rpx; flex-shrink: 0; margin-top: 2rpx; }

/* 全选行 */
.select-all-row { background: #fff; border-radius: 20rpx; padding: 24rpx; display: flex; align-items: center; gap: 16rpx; box-shadow: 0 4rpx 16rpx rgba(0,0,0,.06); }
.select-all-text { font-size: 28rpx; color: #333; }

/* 底部结算栏 */
.footer { position: fixed; bottom: 0; left: 0; right: 0; background: #fff; padding: 20rpx 32rpx 50rpx; display: flex; align-items: center; gap: 20rpx; box-shadow: 0 -4rpx 16rpx rgba(0,0,0,.06); }
.footer-info { flex: 1; }
.selected-label { font-size: 22rpx; color: #999; display: block; margin-bottom: 4rpx; }
.total-row { display: flex; align-items: baseline; gap: 4rpx; }
.total-label { font-size: 24rpx; color: #555; }
.total-price { font-size: 36rpx; font-weight: 800; color: #FF6B6B; }
.checkout-btn { background: #FF6B6B; color: #fff; border-radius: 99rpx; padding: 20rpx 52rpx; font-size: 30rpx; font-weight: 700; border: none; flex-shrink: 0; }
.checkout-btn.disabled { background: #ddd; color: #fff; }
