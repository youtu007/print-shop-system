.page {
  background: var(--color-bg-page);
  min-height: 100vh;
  padding: var(--space-lg) var(--space-lg) 160rpx;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
  gap: 20rpx;
}

.empty-icon-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: var(--color-primary-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--space-sm);
}

.empty-text {
  font-size: var(--font-base);
  color: var(--color-text-tertiary);
}

.go-shop-btn {
  width: auto !important;
  padding: 18rpx 60rpx !important;
  border-radius: var(--radius-pill) !important;
  margin-top: var(--space-md);
  font-size: var(--font-base) !important;
}

/* 商品列表 */
.list {
  background: var(--color-bg-card);
  border-radius: var(--radius-md);
  overflow: hidden;
  box-shadow: var(--shadow-md);
  margin-bottom: var(--space-md);
}

.item-row {
  display: flex;
  align-items: flex-start;
  padding: var(--space-xl) var(--space-lg);
  border-bottom: 1rpx solid var(--color-border);
  gap: 20rpx;
}

.item-row:last-child {
  border-bottom: none;
}

/* 复选框 */
.checkbox {
  width: 44rpx;
  height: 44rpx;
  border-radius: var(--radius-pill);
  border: 3rpx solid #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 6rpx;
  box-sizing: border-box;
  transition: background 0.2s, border-color 0.2s;
}

.checkbox.checked {
  background: var(--color-primary);
  border-color: var(--color-primary);
}

.check-mark {
  font-size: var(--font-sm);
  color: var(--color-text-white);
  font-weight: 700;
  line-height: 1;
}

/* 商品详情 */
.item-body {
  flex: 1;
}

.item-name {
  font-size: var(--font-base);
  font-weight: 700;
  color: var(--color-text-primary);
  display: block;
  margin-bottom: var(--space-xs);
}

.item-price {
  font-size: var(--font-sm);
  color: var(--color-text-tertiary);
  display: block;
  margin-bottom: var(--space-md);
}

.item-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.qty-row {
  display: flex;
  align-items: center;
  gap: var(--space-md);
}

.qty-btn {
  background: var(--color-bg-input);
  color: var(--color-text-primary);
  border-radius: var(--radius-pill);
  width: 52rpx;
  height: 52rpx;
  font-size: var(--font-md);
  line-height: 52rpx;
  text-align: center;
  border: none;
  padding: 0;
  transition: transform 0.15s ease;
}

.qty-btn-active {
  transform: scale(0.9);
  opacity: 0.8;
}

.qty-btn::after {
  border: none;
}

.qty-num {
  font-size: var(--font-base);
  font-weight: 700;
  min-width: 32rpx;
  text-align: center;
  color: var(--color-text-primary);
}

.item-subtotal {
  font-size: var(--font-base);
  font-weight: 800;
  color: var(--color-primary);
}

/* 删除 */
.delete-btn {
  font-size: 36rpx;
  color: #ccc;
  padding: 0 4rpx;
  flex-shrink: 0;
  margin-top: 2rpx;
}

/* 全选行 */
.select-all-row {
  background: var(--color-bg-card);
  border-radius: var(--radius-md);
  padding: var(--space-lg);
  display: flex;
  align-items: center;
  gap: var(--space-md);
  box-shadow: var(--shadow-md);
}

.select-all-text {
  font-size: var(--font-base);
  color: var(--color-text-primary);
}

/* 底部结算栏 */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--color-bg-card);
  padding: 20rpx var(--space-xl) 50rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.footer-info {
  flex: 1;
}

.selected-label {
  font-size: var(--font-xs);
  color: var(--color-text-tertiary);
  display: block;
  margin-bottom: 4rpx;
}

.total-row {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.total-label {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
}

.total-price {
  font-size: var(--font-xl);
  font-weight: 800;
  color: var(--color-primary);
}

/* 结算按钮 */
.checkout-btn {
  background: linear-gradient(135deg, #FF6B6B, #FF8A8A);
  color: var(--color-text-white);
  border-radius: var(--radius-pill);
  padding: 20rpx 52rpx;
  font-size: var(--font-md);
  font-weight: 700;
  border: none;
  flex-shrink: 0;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 107, 0.3);
}

.checkout-btn::after {
  border: none;
}

.checkout-btn.disabled {
  background: #ddd;
  color: var(--color-text-white);
  box-shadow: none;
}
