.page{min-height:100vh;background:var(--color-bg-page);padding:var(--space-lg)}.upload-card{background:var(--color-bg-card);border-radius:var(--radius-lg);padding:var(--space-xl);margin-bottom:var(--space-lg);box-shadow:var(--shadow-sm)}.field{margin-bottom:var(--space-lg)}.field-label{display:block;font-size:var(--font-sm);color:var(--color-text-secondary);margin-bottom:var(--space-sm)}.input-base{background:var(--color-bg-input);border-radius:var(--radius-md);padding:var(--space-md);font-size:var(--font-base)}.photo-grid{display:flex;flex-wrap:wrap;gap:var(--space-sm);margin-bottom:var(--space-lg)}.photo-item{position:relative;width:150rpx;height:150rpx}.photo-item image{width:100%;height:100%;border-radius:var(--radius-md)}.photo-remove{position:absolute;top:-10rpx;right:-10rpx;width:40rpx;height:40rpx;background:var(--color-error);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:28rpx}.photo-add{width:150rpx;height:150rpx;border:2rpx dashed var(--color-border);border-radius:var(--radius-md);display:flex;align-items:center;justify-content:center;font-size:48rpx;color:var(--color-text-tertiary)}.btn-upload{background:var(--color-primary);color:#fff;border:none;padding:var(--space-md);border-radius:var(--radius-md);font-size:var(--font-base);font-weight:600}.btn-upload[disabled]{background:#ccc}.code-tip{background:var(--color-success-bg);padding:var(--space-lg);border-radius:var(--radius-md);margin-bottom:var(--space-lg);display:flex;align-items:center;gap:var(--space-md)}.code{font-size:var(--font-lg);font-weight:700;color:var(--color-success)}.copy{color:var(--color-primary);font-size:var(--font-sm)}.dismiss{margin-left:auto;color:var(--color-text-tertiary)}.loading,.empty-tip{text-align:center;padding:120rpx;color:var(--color-text-tertiary)}.group-list{display:flex;flex-direction:column;gap:var(--space-md)}.group-card{background:var(--color-bg-card);border-radius:var(--radius-lg);padding:var(--space-lg);box-shadow:var(--shadow-sm)}.group-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:var(--space-md)}.group-code{font-family:monospace;font-size:var(--font-lg);font-weight:700;color:var(--color-primary)}.group-status{font-size:var(--font-sm);color:var(--color-warning)}.group-status.paid{color:var(--color-success)}.group-photos{display:flex;flex-wrap:wrap;gap:var(--space-xs);margin-bottom:var(--space-md)}.group-photos image{width:120rpx;height:120rpx;border-radius:var(--radius-sm)}.group-time{font-size:var(--font-xs);color:var(--color-text-tertiary)}