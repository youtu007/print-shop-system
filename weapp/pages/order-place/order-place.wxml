<view class="page"><view class="section-title anim-slide-up anim-delay-1"><view class="section-dot"></view>商品信息</view><view class="product-card anim-slide-up anim-delay-2"><view class="prod-row" wx:for="{{items}}" wx:key="id"><view class="prod-main"><text class="prod-name">{{item.name}}</text><view wx:if="{{item.file_info}}" class="prod-file-info"><text>📄 {{item.file_info.file_name}} · {{item.file_info.page_count}}张</text></view><text class="prod-meta">× {{item.qty}}</text></view><text class="prod-price">¥{{item.subtotal}}</text></view><view class="subtotal-row"><text class="subtotal-label">共 {{totalQty}} 件</text><view class="subtotal-right"><text class="subtotal-label">小计 </text><text class="subtotal-price">¥{{totalPrice}}</text></view></view></view><view class="section-title anim-slide-up anim-delay-3"><view class="section-dot"></view>收货信息<text class="addr-book-link" bindtap="goAddressBook">从地址簿选择</text></view><view class="form-card anim-slide-up anim-delay-4"><view class="field-row"><text class="field-label">姓名</text><view class="input-wrap"><input class="input-inner" placeholder="请输入姓名" data-field="name" bindinput="onInput" value="{{form.name}}"/></view></view><view class="divider"></view><view class="field-row"><text class="field-label">手机号</text><view class="input-wrap"><input class="input-inner" placeholder="请输入手机号" data-field="phone" bindinput="onInput" value="{{form.phone}}" type="number"/></view></view><view class="divider"></view><view class="field-row"><text class="field-label">地址</text><view class="input-wrap"><input class="input-inner" placeholder="请输入配送地址" data-field="address" bindinput="onInput" value="{{form.address}}"/></view></view></view><view class="footer anim-fade-in"><view class="footer-total"><text class="footer-label">合计</text><text class="footer-price">¥{{totalPrice}}</text></view><button class="submit-btn" bindtap="placeOrder">提交订单</button></view></view>