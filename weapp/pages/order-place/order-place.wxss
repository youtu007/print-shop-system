.page { background: #FFFBF5; min-height: 100vh; padding: 24rpx 24rpx 160rpx; }
.section-title { font-size: 26rpx; color: #999; font-weight: 600; margin: 24rpx 0 12rpx; padding-left: 4rpx; }

/* Product card */
.product-card { background: #fff; border-radius: 20rpx; padding: 0 28rpx; box-shadow: 0 4rpx 16rpx rgba(0,0,0,.06); }
.prod-row { display: flex; justify-content: space-between; align-items: center; padding: 24rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.prod-main { flex: 1; }
.prod-name { font-size: 28rpx; font-weight: 700; color: #333; display: block; margin-bottom: 4rpx; }
.prod-meta { font-size: 24rpx; color: #999; }
.prod-price { font-size: 28rpx; font-weight: 700; color: #FF6B6B; flex-shrink: 0; }
.subtotal-row { display: flex; justify-content: space-between; align-items: center; padding: 20rpx 0; }
.subtotal-right { display: flex; align-items: baseline; gap: 4rpx; }
.subtotal-label { font-size: 24rpx; color: #999; }
.subtotal-price { font-size: 30rpx; font-weight: 800; color: #FF6B6B; }

/* Form card */
.form-card { background: #fff; border-radius: 20rpx; padding: 0 28rpx; box-shadow: 0 4rpx 16rpx rgba(0,0,0,.06); }
.field-row { display: flex; align-items: center; padding: 28rpx 0; gap: 20rpx; }
.field-label { font-size: 28rpx; color: #333; font-weight: 600; width: 88rpx; flex-shrink: 0; }
.input-wrap { flex: 1; }
.input-inner { font-size: 28rpx; color: #333; width: 100%; }
.divider { height: 1rpx; background: #f5f5f5; }

/* Footer */
.footer { position: fixed; bottom: 0; left: 0; right: 0; background: #fff; padding: 20rpx 32rpx 50rpx; display: flex; align-items: center; gap: 24rpx; box-shadow: 0 -4rpx 16rpx rgba(0,0,0,.06); }
.footer-total { display: flex; flex-direction: column; flex: 1; }
.footer-label { font-size: 22rpx; color: #999; }
.footer-price { font-size: 36rpx; font-weight: 800; color: #FF6B6B; }
.submit-btn { background: #FF6B6B; color: #fff; border-radius: 16rpx; padding: 22rpx 48rpx; font-size: 30rpx; font-weight: 700; border: none; flex-shrink: 0; }
