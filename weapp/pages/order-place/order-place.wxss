.page{background:var(--color-bg-page);min-height:100vh;padding:var(--space-lg) var(--space-lg) 160rpx}.section-title{display:flex;align-items:center;font-size:var(--font-sm);color:var(--color-text-tertiary);font-weight:600;margin:var(--space-lg) 0 var(--space-sm);padding-left:4rpx}.section-dot{width:8rpx;height:8rpx;border-radius:50%;background:var(--color-primary);margin-right:12rpx;flex-shrink:0}
.addr-book-link{margin-left:auto;font-size:var(--font-sm);color:var(--color-primary);font-weight:600}.product-card{background:var(--color-bg-card);border-radius:var(--radius-lg);padding:0 28rpx;box-shadow:var(--shadow-md)}.prod-row{display:flex;justify-content:space-between;align-items:center;padding:var(--space-lg) 0;border-bottom:1rpx solid var(--color-border)}.prod-row:last-of-type{border-bottom:none}.prod-main{flex:1}.prod-name{font-size:var(--font-base);font-weight:700;color:var(--color-text-primary);display:block;margin-bottom:4rpx}.prod-meta{font-size:var(--font-sm);color:var(--color-text-tertiary)}.prod-price{font-size:var(--font-base);font-weight:700;color:var(--color-primary);flex-shrink:0}.subtotal-row{display:flex;justify-content:space-between;align-items:center;padding:20rpx 0}.subtotal-right{display:flex;align-items:baseline;gap:4rpx}.subtotal-label{font-size:var(--font-sm);color:var(--color-text-tertiary)}.subtotal-price{font-size:var(--font-md);font-weight:800;color:var(--color-primary)}.form-card{background:var(--color-bg-card);border-radius:var(--radius-lg);padding:0 28rpx;box-shadow:var(--shadow-md)}.field-row{display:flex;align-items:center;padding:28rpx 0;gap:20rpx}.field-label{font-size:var(--font-base);color:var(--color-text-primary);font-weight:600;width:88rpx;flex-shrink:0}.input-wrap{flex:1;border-bottom:2rpx solid transparent;transition:border-color 0.3s ease;padding-bottom:4rpx}.input-wrap:active{border-bottom-color:var(--color-primary)}.input-inner{font-size:var(--font-base);color:var(--color-text-primary);width:100%}.divider{height:1rpx;background:var(--color-border)}.footer{position:fixed;bottom:0;left:0;right:0;background:var(--color-bg-card);padding:20rpx var(--space-xl) 50rpx;display:flex;align-items:center;justify-content:space-between;gap:var(--space-lg);box-shadow:0 -4rpx 16rpx rgba(0,0,0,0.06)}.footer-total{display:flex;flex-direction:column;flex:1}.footer-label{font-size:var(--font-xs);color:var(--color-text-tertiary)}.footer-price{font-size:var(--font-xl);font-weight:800;color:var(--color-primary)}.submit-btn{background:linear-gradient(135deg,var(--color-primary),var(--color-primary-light));color:var(--color-text-white);border-radius:var(--radius-md);padding:22rpx 48rpx;font-size:var(--font-md);font-weight:700;border:none;flex-shrink:0;box-shadow:0 4rpx 16rpx rgba(255,107,107,0.3)}.submit-btn::after{border:none}.pay-mask{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.5);z-index:200}.pay-popup{position:fixed;left:0;right:0;bottom:0;z-index:201;transform:translateY(100%);transition:transform 0.3s ease}.pay-popup.show{transform:translateY(0)}.pay-card{background:#fff;border-radius:32rpx 32rpx 0 0;padding:48rpx 32rpx 80rpx;text-align:center;position:relative}.pay-close{position:absolute;top:24rpx;right:32rpx;font-size:36rpx;color:#9CA3AF;padding:8rpx}.pay-title{font-size:36rpx;font-weight:800;color:#1F2937;margin-bottom:32rpx}.pay-placeholder{margin:24rpx auto}.pay-placeholder-img{width:300rpx;height:200rpx}.pay-amount{margin:24rpx 0 32rpx;display:flex;flex-direction:column;align-items:center;gap:8rpx}.pay-label{font-size:24rpx;color:#9CA3AF}.pay-price{font-size:44rpx;font-weight:800;color:#FF6B6B}.pay-confirm-btn{margin-bottom:16rpx}.pay-cancel-btn{}
.prod-file-info{font-size:22rpx;color:var(--color-primary);margin:4rpx 0}