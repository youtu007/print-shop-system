<view class="page"><view class="login-card card-base anim-slide-up"><view class="login-header"><view class="icon-circle-wrap icon-circle-lg" style="background:rgba(255,255,255,0.2);color:#fff;"><view class="css-icon css-icon-lg icon-lock"></view></view><text class="login-title">管理员登录</text><text class="login-sub">打印小站管理后台</text></view><view class="field"><text class="field-label">账号</text><input class="input-base" placeholder="请输入管理员账号" value="{{username}}" bindinput="onInputUsername" /></view><view class="field"><text class="field-label">密码</text><input class="input-base" placeholder="请输入密码" password value="{{password}}" bindinput="onInputPassword" /></view><button class="btn-primary-g" bindtap="doLogin" disabled="{{loading}}"> {{loading ? '登录中...' : '登 录'}} </button><view wx:if="{{error}}" class="error-tip">{{error}}</view></view></view>