<view class="page">
  <view class="login-card card-base anim-slide-up">
    <view class="login-header">
      <view class="icon-circle-wrap icon-circle-lg" style="background:rgba(255,255,255,0.2);color:#fff;">
        <view class="css-icon css-icon-lg icon-lock"></view>
      </view>
      <text class="login-title">管理员登录</text>
      <text class="login-sub">打印小站管理后台</text>
    </view>

    <view class="field">
      <text class="field-label">账号</text>
      <input class="input-base" placeholder="请输入管理员账号" value="{{username}}" bindinput="onInputUsername" />
    </view>
    <view class="field">
      <text class="field-label">密码</text>
      <input class="input-base" placeholder="请输入密码" password value="{{password}}" bindinput="onInputPassword" />
    </view>

    <button class="btn-primary-g" bindtap="doLogin" disabled="{{loading}}">
      {{loading ? '登录中...' : '登 录'}}
    </button>

    <view wx:if="{{error}}" class="error-tip">{{error}}</view>
  </view>

  <view class="demo-tip anim-slide-up anim-delay-2">
    <text class="demo-title">演示账号</text>
    <view class="demo-row"><text class="demo-label">超管</text><text class="demo-val">admin / admin123</text></view>
    <view class="demo-row"><text class="demo-label">打印</text><text class="demo-val">printer_user / 123456</text></view>
    <view class="demo-row"><text class="demo-label">商城</text><text class="demo-val">shop_user / 123456</text></view>
    <view class="demo-row"><text class="demo-label">配送</text><text class="demo-val">delivery_user / 123456</text></view>
  </view>
</view>
