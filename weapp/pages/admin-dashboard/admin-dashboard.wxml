<view class="page"><view class="header anim-fade-in"><view class="header-bg"></view><view class="header-content"><view class="role-badge role-{{role}}"></view></view></view><block wx:if="{{loading}}"><view class="skeleton-grid"><view class="skeleton-card" wx:for="{{4}}" wx:key="index"><view class="skeleton-line"></view><view class="skeleton-line short"></view></view></view></block><block wx:else><view class="stat-grid"><view class="stat-card anim-slide-up anim-delay-1" wx:if="{{stats.online_printers !== undefined}}"><text class="stat-num">{{stats.online_printers}}<text class="stat-total">/{{stats.total_printers}}</text></text><text class="stat-label">在线打印机</text></view><view class="stat-card anim-slide-up anim-delay-2" wx:if="{{stats.today_jobs !== undefined}}"><text class="stat-num">{{stats.today_jobs}}</text><text class="stat-label">今日任务</text></view><view class="stat-card anim-slide-up anim-delay-2" wx:if="{{stats.total_groups !== undefined}}"><text class="stat-num">{{stats.total_groups}}</text><text class="stat-label">照片编组</text></view><view class="stat-card anim-slide-up anim-delay-3" wx:if="{{stats.pending_orders !== undefined}}"><text class="stat-num">{{stats.pending_orders}}</text><text class="stat-label">待处理订单</text></view><view class="stat-card anim-slide-up anim-delay-3" wx:if="{{stats.total_products !== undefined}}"><text class="stat-num">{{stats.total_products}}</text><text class="stat-label">商品总数</text></view><view class="stat-card anim-slide-up anim-delay-4" wx:if="{{stats.packing_orders !== undefined}}"><text class="stat-num">{{stats.packing_orders}}</text><text class="stat-label">待发货</text></view><view class="stat-card anim-slide-up anim-delay-4" wx:if="{{stats.shipping_orders !== undefined}}"><text class="stat-num">{{stats.shipping_orders}}</text><text class="stat-label">配送中</text></view><view class="stat-card anim-slide-up anim-delay-5" wx:if="{{stats.total_admins !== undefined}}"><text class="stat-num">{{stats.total_admins}}</text><text class="stat-label">管理员数</text></view></view></block><view class="section-title anim-slide-up anim-delay-3">功能菜单</view><view class="menu-grid"><view class="menu-item anim-slide-up anim-delay-{{index + 4}}" wx:for="{{menus}}" wx:key="key" bindtap="goPage" data-key="{{item.key}}"><view class="icon-circle-wrap icon-circle-md {{item.color}}"><view class="css-icon css-icon-md {{item.icon}}"></view></view><text class="menu-label">{{item.title}}</text></view></view><view class="logout-area anim-slide-up anim-delay-6"><button class="btn-ghost-g" bindtap="logout">退出登录</button></view></view>