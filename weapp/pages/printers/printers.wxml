<view class="page">
  <view class="title">打印机状态</view>

  <!-- 骨架屏 -->
  <view wx:if="{{loading}}">
    <view class="skeleton-card" wx:for="{{[1,2,3]}}" wx:key="*this">
      <view class="sk-line sk-title"></view>
      <view class="sk-line sk-short"></view>
      <view class="sk-line sk-short"></view>
    </view>
  </view>

  <!-- 数据 -->
  <view wx:else>
    <view wx:if="{{!printers.length}}" class="empty">暂无可用打印机</view>
    <view class="card" wx:for="{{printers}}" wx:key="id">
      <view class="row">
        <text class="name">{{item.name}}</text>
        <view wx:if="{{item.status === 'online'}}" class="badge-success">
          <view class="pulse-dot" style="margin-right:8rpx"></view>
          在线
        </view>
        <view wx:elif="{{item.status === 'busy'}}" class="badge-warning">忙碌</view>
        <view wx:else class="badge badge-offline">离线</view>
      </view>
      <view class="loc-row">
        <view class="css-icon css-icon-sm icon-location" style="color:var(--color-text-tertiary)"></view>
        <text class="loc">{{item.location}}</text>
      </view>
      <view class="paper-row">
        <view class="paper-label-row">
          <view class="css-icon css-icon-sm icon-doc" style="color:var(--color-text-tertiary)"></view>
          <text class="paper-label">剩余纸张</text>
        </view>
        <view class="paper-bar-wrap">
          <view class="paper-bar paper-bar-{{item.paperLevel}}" style="width:{{item.paper_remaining/500*100 > 100 ? 100 : item.paper_remaining/500*100}}%"></view>
        </view>
        <text class="paper-num">{{item.paper_remaining}} 张</text>
      </view>
    </view>
  </view>
</view>
