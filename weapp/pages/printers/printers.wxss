.page{background:var(--color-bg-page);min-height:100vh;padding:var(--space-lg)}.title{font-size:var(--font-xl);font-weight:800;color:var(--color-text-primary);margin-bottom:var(--space-lg);text-align:center}.card{background:var(--color-bg-card);border-radius:var(--radius-lg);padding:var(--space-xl);margin-bottom:var(--space-lg);box-shadow:var(--shadow-md)}.row{display:flex;justify-content:space-between;align-items:center;margin-bottom:var(--space-sm)}.name{font-weight:700;font-size:var(--font-md);color:var(--color-text-primary)}.badge-offline{display:inline-flex;align-items:center;padding:6rpx 16rpx;border-radius:var(--radius-pill);font-size:var(--font-xs);font-weight:600;background:var(--color-bg-input);color:var(--color-text-tertiary)}.loc-row{display:flex;align-items:center;gap:6rpx;margin-bottom:14rpx}.loc{font-size:var(--font-sm);color:var(--color-text-tertiary)}.paper-row{display:flex;align-items:center;gap:var(--space-sm)}.paper-label-row{display:flex;align-items:center;gap:6rpx;flex-shrink:0}.paper-label{font-size:var(--font-sm);color:var(--color-text-tertiary)}.paper-bar-wrap{flex:1;height:12rpx;background:var(--color-border);border-radius:6rpx;overflow:hidden}.paper-bar{height:100%;border-radius:6rpx;transition:width 0.3s}.paper-bar-high{background:linear-gradient(90deg,#10B981,#34D399)}.paper-bar-mid{background:linear-gradient(90deg,#F59E0B,#FBBF24)}.paper-bar-low{background:linear-gradient(90deg,#EF4444,#F87171)}.paper-num{font-size:var(--font-sm);color:var(--color-text-secondary);font-weight:600;flex-shrink:0}.empty{display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:40vh;color:var(--color-text-tertiary);font-size:var(--font-base)}.skeleton-card{background:var(--color-bg-card);border-radius:var(--radius-lg);padding:var(--space-xl);margin-bottom:var(--space-lg);box-shadow:var(--shadow-sm)}.sk-line{background:linear-gradient(90deg,var(--color-border) 25%,#e5e7eb 50%,var(--color-border) 75%);background-size:400% 100%;border-radius:var(--radius-sm);margin-bottom:var(--space-md);animation:shimmer 1.5s infinite}.sk-title{height:36rpx;width:60%}.sk-short{height:24rpx;width:40%}