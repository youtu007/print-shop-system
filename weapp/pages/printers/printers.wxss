.page { background: #FFFBF5; min-height: 100vh; padding: 24rpx; }
.title { font-size: 36rpx; font-weight: 800; margin-bottom: 24rpx; }
.card { background: #fff; border-radius: 24rpx; padding: 28rpx; margin-bottom: 20rpx; box-shadow: 0 4rpx 16rpx rgba(0,0,0,.06); }
.row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10rpx; }
.name { font-weight: 700; font-size: 30rpx; }
.badge { display: flex; align-items: center; justify-content: center; padding: 6rpx 20rpx; border-radius: 99rpx; font-size: 22rpx; font-weight: 600; }
.online { background: #e8f9ec; color: #27ae60; }
.busy { background: #fff3e0; color: #e67e22; }
.offline { background: #f0f0f0; color: #999; }
.loc { font-size: 24rpx; color: #999; display: block; margin-bottom: 14rpx; }
.paper-row { display: flex; align-items: center; gap: 12rpx; }
.paper-label { font-size: 24rpx; color: #999; flex-shrink: 0; }
.paper-bar-wrap { flex: 1; height: 12rpx; background: #f0f0f0; border-radius: 6rpx; overflow: hidden; }
.paper-bar { height: 100%; background: linear-gradient(90deg, #6BCB77, #4CAF50); border-radius: 6rpx; transition: width 0.3s; }
.paper-num { font-size: 24rpx; color: #555; font-weight: 600; flex-shrink: 0; }
.empty { text-align: center; color: #bbb; font-size: 28rpx; padding: 80rpx 0; }

/* 骨架屏 */
.skeleton-card { background: #fff; border-radius: 24rpx; padding: 28rpx; margin-bottom: 20rpx; }
.sk-line { background: #f0f0f0; border-radius: 8rpx; margin-bottom: 16rpx;
  animation: shimmer 1.2s infinite; }
.sk-title { height: 36rpx; width: 60%; }
.sk-short { height: 24rpx; width: 40%; }
@keyframes shimmer {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.4; }
}
