.page { background: var(--color-bg-page); min-height: 100vh; padding: var(--space-lg); }

/* 轮播图 */
.banner-swiper {
  width: 100%;
  height: 280rpx;
  border-radius: var(--radius-lg);
  overflow: hidden;
  margin-bottom: var(--space-lg);
}
.banner-image {
  width: 100%;
  height: 100%;
}

/* Tab - 毛玻璃效果 */
.tabs {
  display: flex; position: relative;
  background: #fff;
  border-radius: var(--radius-md); padding: var(--space-xs);
  margin-bottom: var(--space-lg);
  box-shadow: var(--shadow-md);
}
.tab {
  flex: 1; text-align: center; padding: var(--space-md);
  border-radius: var(--radius-sm); font-size: var(--font-base);
  font-weight: 600; color: var(--color-text-tertiary);
  position: relative; z-index: 1;
  transition: color 0.3s;
}
.tab.active { background: var(--color-primary); color: var(--color-text-white); }
.tab-indicator {
  position: absolute; bottom: 0; height: 6rpx; width: 30%;
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));
  border-radius: var(--radius-pill);
  transform: translateX(-50%);
  transition: left 0.3s ease;
}

/* Card */
.card {
  background: var(--color-bg-card); border-radius: var(--radius-lg);
  padding: var(--space-xl); margin-bottom: var(--space-lg);
  box-shadow: var(--shadow-md);
}
.section-title {
  font-size: var(--font-lg); font-weight: 700;
  color: var(--color-text-primary); margin-bottom: var(--space-lg);
}

/* Buttons */
.btn {
  display: block; width: 100%; border: none;
  border-radius: var(--radius-md); padding: var(--space-lg);
  font-size: var(--font-md); font-weight: 700;
  text-align: center; margin-bottom: var(--space-md);
}
.btn-primary {
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));
  color: var(--color-text-white);
  box-shadow: 0 4rpx 16rpx rgba(255,107,107,0.3);
}
.btn-primary[disabled] { background: #ccc; box-shadow: none; }
.btn-green {
  background: linear-gradient(135deg, var(--color-success), #34D399);
  color: var(--color-text-white);
}
.btn-ghost { background: var(--color-bg-input); color: var(--color-text-secondary); }
.input-wrap {
  background: var(--color-bg-input); border-radius: var(--radius-md);
  padding: var(--space-lg); margin-bottom: 20rpx;
}
.input-inner { width: 100%; font-size: var(--font-md); color: var(--color-text-primary); }
.error-text {
  color: var(--color-error); font-size: var(--font-sm);
  display: block; margin-bottom: var(--space-md);
}

/* 编组 */
.group-header {
  display: flex; align-items: center;
  justify-content: space-between; margin-bottom: 20rpx;
}
.group-title { font-size: var(--font-lg); font-weight: 700; color: var(--color-text-primary); }
.badge-paid {
  font-size: var(--font-xs); padding: 6rpx 16rpx;
  border-radius: var(--radius-pill); font-weight: 600;
}
.badge-paid.paid { background: var(--color-success-bg); color: var(--color-success); }
.badge-paid.unpaid { background: var(--color-primary-bg); color: var(--color-primary); }
.photo-grid { display: flex; flex-wrap: wrap; gap: var(--space-sm); margin-bottom: var(--space-lg); }
.photo-thumb { width: 180rpx; height: 180rpx; border-radius: var(--radius-sm); }

/* 步骤指示器 */
.steps {
  display: flex; align-items: center;
  margin-bottom: 28rpx; padding: 0 4rpx;
}
.step {
  display: flex; flex-direction: column;
  align-items: center; gap: 6rpx; flex-shrink: 0;
}
.step-dot {
  width: 48rpx; height: 48rpx; border-radius: 50%;
  background: var(--color-border); color: var(--color-text-tertiary);
  font-size: var(--font-xs); font-weight: 700;
  display: flex; align-items: center; justify-content: center;
  transition: all 0.3s;
}
.step.active .step-dot {
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));
  color: var(--color-text-white);
  box-shadow: 0 4rpx 16rpx rgba(255,107,107,0.35);
}
.step.done .step-dot {
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));
  color: var(--color-text-white);
  box-shadow: 0 4rpx 16rpx rgba(255,107,107,0.35);
}
.step-label { font-size: 20rpx; color: var(--color-text-tertiary); white-space: nowrap; }
.step.active .step-label, .step.done .step-label { color: var(--color-primary); }
.step-line {
  flex: 1; height: 4rpx; background: var(--color-border);
  margin: 0 4rpx; margin-bottom: 20rpx;
  transition: background 0.3s;
}
.step-line.done {
  background: linear-gradient(90deg, var(--color-primary), var(--color-primary-light));
}

/* Step1: 类型选择 */
.type-grid { display: flex; gap: 20rpx; }
.type-card {
  flex: 1; background: var(--color-bg-input);
  border-radius: var(--radius-md); padding: 28rpx 16rpx;
  text-align: center; border: 3rpx solid transparent;
  transition: all 0.3s;
}
.type-card.selected {
  background: linear-gradient(135deg, #FFF5F5, #FFE8E8);
  border-color: var(--color-primary);
  box-shadow: 0 4rpx 16rpx rgba(255,107,107,0.15);
}
.type-card.doc { position: relative; }
.type-icon-area {
  display: flex; align-items: center; justify-content: center;
  margin-bottom: var(--space-sm); height: 64rpx;
}
.type-name {
  font-size: var(--font-base); font-weight: 700;
  display: block; margin-bottom: 6rpx; color: var(--color-text-primary);
}
.type-desc {
  font-size: var(--font-xs); color: var(--color-text-tertiary);
  display: block; margin-bottom: var(--space-md);
}

/* 彩印/黑白 toggle */
.color-toggle {
  display: flex; background: var(--color-border);
  border-radius: var(--radius-md); padding: 4rpx; margin-top: var(--space-xs);
}
.color-opt {
  flex: 1; font-size: var(--font-xs); font-weight: 600;
  padding: 8rpx 0; border-radius: var(--radius-sm);
  color: var(--color-text-tertiary); text-align: center;
  transition: all 0.2s;
}
.color-active {
  background: var(--color-bg-card); color: var(--color-primary);
  box-shadow: var(--shadow-sm);
}
.bw-active {
  background: var(--color-bg-card); color: var(--color-text-secondary);
  box-shadow: var(--shadow-sm);
}

/* Step2: 上传区 */
.upload-area {
  background: linear-gradient(var(--color-bg-card), var(--color-bg-card)) padding-box,
              linear-gradient(135deg, #FF6B6B, #FFB3B3) border-box;
  border: 3rpx solid transparent;
  border-radius: var(--radius-md); padding: 60rpx 32rpx;
  text-align: center; margin-bottom: var(--space-lg);
  display: flex; flex-direction: column; align-items: center; gap: var(--space-sm);
}
.doc-area {
  background: linear-gradient(var(--color-bg-card), var(--color-bg-card)) padding-box,
              linear-gradient(135deg, #3B82F6, #93C5FD) border-box;
}
.upload-hint {
  font-size: var(--font-md); color: var(--color-primary);
  font-weight: 600; display: block;
}
.doc-area .upload-hint { color: var(--color-info); }
.upload-sub { font-size: var(--font-sm); color: var(--color-text-tertiary); display: block; }
.color-bar {
  display: flex; justify-content: space-between; align-items: center;
  background: var(--color-bg-input); border-radius: var(--radius-sm);
  padding: var(--space-md) 20rpx; margin-bottom: 20rpx;
}
.color-bar-label { font-size: 26rpx; color: var(--color-text-secondary); }
.color-bar-val { font-size: 26rpx; font-weight: 700; }
.text-coral { color: var(--color-primary); }
.text-gray { color: var(--color-text-secondary); }

/* Step3: 规格 */
.photo-preview-row { display: flex; gap: var(--space-sm); margin-bottom: var(--space-lg); flex-wrap: wrap; }
.preview-thumb { width: 130rpx; height: 130rpx; border-radius: var(--radius-sm); }
.preview-more {
  width: 130rpx; height: 130rpx; border-radius: var(--radius-sm);
  background: var(--color-bg-input);
  display: flex; align-items: center; justify-content: center;
  font-size: var(--font-base); color: var(--color-text-tertiary); font-weight: 700;
}
.doc-summary {
  display: flex; align-items: center; gap: 20rpx;
  background: var(--color-info-bg); border-radius: var(--radius-md);
  padding: 20rpx; margin-bottom: var(--space-lg);
}
.doc-icon-big {
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.doc-info { flex: 1; overflow: hidden; }
.doc-name {
  font-size: 26rpx; font-weight: 600; color: var(--color-text-primary);
  display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.doc-mode { font-size: var(--font-xs); display: block; margin-top: 6rpx; }
.field-row {
  display: flex; align-items: center; justify-content: space-between;
  padding: 20rpx 0; border-bottom: 1rpx solid var(--color-border);
}
.field-label { font-size: var(--font-base); color: var(--color-text-secondary); font-weight: 600; }
.picker-val { font-size: var(--font-base); color: var(--color-primary); font-weight: 600; }
.picker-arrow { font-size: var(--font-xs); color: var(--color-text-tertiary); }
.count-input {
  text-align: right; font-size: var(--font-md);
  color: var(--color-primary); font-weight: 700;
  width: 120rpx; border: none; background: transparent;
}
.no-printer {
  font-size: 26rpx; color: var(--color-text-tertiary);
  text-align: center; padding: var(--space-md) 0;
}

/* Step4: 确认 */
.doc-confirm { text-align: center; padding: 20rpx 0 8rpx; }
.doc-confirm-icon-wrap {
  display: flex; align-items: center; justify-content: center;
  width: 80rpx; height: 80rpx; margin: 0 auto var(--space-sm);
  background: var(--color-info-bg); border-radius: 50%;
}
.confirm-title {
  font-size: var(--font-base); font-weight: 700;
  color: var(--color-text-primary); margin-top: var(--space-xs);
  margin-bottom: var(--space-md);
}
.layout-preview {
  width: 100%; border-radius: var(--radius-md);
  margin-bottom: 20rpx; display: block;
}
.spec-summary {
  background: var(--color-bg-input); border-radius: var(--radius-md);
  padding: var(--space-md) 20rpx; margin-bottom: var(--space-lg);
}
.spec-row {
  display: flex; justify-content: space-between;
  align-items: center; padding: 10rpx 0;
  border-bottom: 1rpx solid var(--color-border);
}
.spec-row:last-child { border-bottom: none; }
.spec-key { font-size: 26rpx; color: var(--color-text-tertiary); }
.spec-val { font-size: 26rpx; color: var(--color-text-primary); font-weight: 600; }
.spec-filename {
  max-width: 340rpx; overflow: hidden;
  text-overflow: ellipsis; white-space: nowrap; font-size: var(--font-sm);
}

/* Step5: 完成 */
.done-card { text-align: center; }
.done-check-wrap {
  width: 120rpx; height: 120rpx; border-radius: 50%;
  background: linear-gradient(135deg, var(--color-success), #34D399);
  display: flex; align-items: center; justify-content: center;
  margin: 0 auto var(--space-lg);
  box-shadow: 0 8rpx 24rpx rgba(16,185,129,0.3);
}
.done-check-wrap .css-icon { color: var(--color-text-white); }
.done-title {
  font-size: var(--font-xl); font-weight: 700;
  color: var(--color-text-primary); margin-bottom: var(--space-xl);
}
.status-row {
  display: flex; align-items: center; justify-content: center;
  gap: var(--space-lg);
  padding: 20rpx; background: var(--color-bg-input);
  border-radius: var(--radius-md); margin-bottom: var(--space-md);
}
.status-label { font-size: var(--font-base); color: var(--color-text-secondary); }
.status-badge {
  padding: 10rpx 24rpx; border-radius: var(--radius-pill);
  font-size: 26rpx; font-weight: 700;
}
.status-badge.pending { background: var(--color-warning-bg); color: var(--color-warning); }
.status-badge.printing { background: var(--color-info-bg); color: var(--color-info); }
.status-badge.done { background: var(--color-success-bg); color: var(--color-success); }
.job-id {
  font-size: var(--font-xs); color: var(--color-text-tertiary);
  margin-bottom: var(--space-xl); word-break: break-all;
}

/* ===== 支付弹窗样式 ===== */
.pay-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5); z-index: 200;
}
.pay-popup {
  position: fixed; left: 0; right: 0; bottom: 0; z-index: 201;
  transform: translateY(100%); transition: transform 0.3s ease;
}
.pay-popup.show { transform: translateY(0); }
.pay-card {
  background: #fff; border-radius: 32rpx 32rpx 0 0;
  padding: 48rpx 32rpx 80rpx; text-align: center;
  position: relative;
}
.pay-close {
  position: absolute; top: 24rpx; right: 32rpx;
  font-size: 36rpx; color: #9CA3AF; padding: 8rpx;
}
.pay-title {
  font-size: 36rpx; font-weight: 800; color: #1F2937;
  margin-bottom: 32rpx;
}
.pay-placeholder { margin: 24rpx auto; }
.pay-placeholder-img { width: 300rpx; height: 200rpx; }
.pay-amount {
  margin: 24rpx 0 32rpx; display: flex; flex-direction: column;
  align-items: center; gap: 8rpx;
}
.pay-label { font-size: 24rpx; color: #9CA3AF; }
.pay-price { font-size: 44rpx; font-weight: 800; color: #FF6B6B; }
.pay-confirm-btn { margin-bottom: 16rpx; }
.pay-cancel-btn { }
