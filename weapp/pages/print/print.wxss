.page { background: #FFFBF5; min-height: 100vh; padding: 24rpx; }

/* Tab */
.tabs { display: flex; background: #fff; border-radius: 20rpx; padding: 8rpx; margin-bottom: 24rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06); }
.tab { flex: 1; text-align: center; padding: 16rpx; border-radius: 16rpx; font-size: 28rpx; font-weight: 600; color: #999; }
.tab.active { background: #FF6B6B; color: #fff; }

/* Card */
.card { background: #fff; border-radius: 24rpx; padding: 32rpx; margin-bottom: 24rpx; box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.07); }
.section-title { font-size: 32rpx; font-weight: 700; color: #333; margin-bottom: 24rpx; }

/* Buttons */
.btn { display: block; width: 100%; border: none; border-radius: 16rpx; padding: 24rpx; font-size: 30rpx; font-weight: 700; text-align: center; margin-bottom: 16rpx; }
.btn-primary { background: #FF6B6B; color: #fff; }
.btn-primary[disabled] { background: #ccc; }
.btn-green { background: #6BCB77; color: #fff; }
.btn-ghost { background: #f5f5f5; color: #666; }
.input-wrap { background: #f8f8f8; border-radius: 16rpx; padding: 24rpx; margin-bottom: 20rpx; }
.input-inner { width: 100%; font-size: 30rpx; color: #333; }
.error-text { color: #e74c3c; font-size: 24rpx; display: block; margin-bottom: 16rpx; }

/* 编组 */
.group-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20rpx; }
.group-title { font-size: 32rpx; font-weight: 700; color: #333; }
.badge-paid { font-size: 22rpx; padding: 6rpx 16rpx; border-radius: 20rpx; font-weight: 600; }
.badge-paid.paid { background: #e8f8ea; color: #6BCB77; }
.badge-paid.unpaid { background: #fff0e6; color: #FF6B6B; }
.photo-grid { display: flex; flex-wrap: wrap; gap: 12rpx; margin-bottom: 24rpx; }
.photo-thumb { width: 180rpx; height: 180rpx; border-radius: 12rpx; }

/* 步骤指示器 */
.steps { display: flex; align-items: center; margin-bottom: 28rpx; padding: 0 4rpx; }
.step { display: flex; flex-direction: column; align-items: center; gap: 6rpx; flex-shrink: 0; }
.step-dot { width: 48rpx; height: 48rpx; border-radius: 50%; background: #e8e8e8; color: #bbb; font-size: 22rpx; font-weight: 700; display: flex; align-items: center; justify-content: center; }
.step.active .step-dot { background: #FF6B6B; color: #fff; }
.step.done .step-dot { background: #FF6B6B; color: #fff; }
.step-label { font-size: 20rpx; color: #bbb; white-space: nowrap; }
.step.active .step-label, .step.done .step-label { color: #FF6B6B; }
.step-line { flex: 1; height: 4rpx; background: #e8e8e8; margin: 0 4rpx; margin-bottom: 20rpx; }
.step-line.done { background: #FF6B6B; }

/* Step1: 类型选择 */
.type-grid { display: flex; gap: 20rpx; }
.type-card { flex: 1; background: #f8f8f8; border-radius: 20rpx; padding: 28rpx 16rpx; text-align: center; border: 3rpx solid transparent; transition: all 0.2s; }
.type-card.selected { background: #fff5f5; border-color: #FF6B6B; }
.type-card.doc { position: relative; }
.type-icon { font-size: 64rpx; display: block; margin-bottom: 12rpx; }
.type-name { font-size: 28rpx; font-weight: 700; display: block; margin-bottom: 6rpx; color: #333; }
.type-desc { font-size: 22rpx; color: #999; display: block; margin-bottom: 16rpx; }

/* 彩印/黑白 toggle */
.color-toggle { display: flex; background: #efefef; border-radius: 20rpx; padding: 4rpx; margin-top: 8rpx; }
.color-opt { flex: 1; font-size: 22rpx; font-weight: 600; padding: 8rpx 0; border-radius: 16rpx; color: #999; text-align: center; }
.color-active { background: #fff; color: #FF6B6B; box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.1); }
.bw-active { background: #fff; color: #555; box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.1); }

/* Step2: 上传区 */
.upload-area { background: #fff8f8; border: 3rpx dashed #ffb3b3; border-radius: 20rpx; padding: 60rpx 32rpx; text-align: center; margin-bottom: 24rpx; }
.doc-area { background: #f5f8ff; border-color: #b3c8ff; }
.upload-icon { font-size: 80rpx; display: block; margin-bottom: 16rpx; }
.upload-hint { font-size: 30rpx; color: #FF6B6B; font-weight: 600; display: block; margin-bottom: 8rpx; }
.doc-area .upload-hint { color: #5580FF; }
.upload-sub { font-size: 24rpx; color: #bbb; display: block; }
.color-bar { display: flex; justify-content: space-between; align-items: center; background: #f8f8f8; border-radius: 12rpx; padding: 16rpx 20rpx; margin-bottom: 20rpx; }
.color-bar-label { font-size: 26rpx; color: #666; }
.color-bar-val { font-size: 26rpx; font-weight: 700; }
.text-coral { color: #FF6B6B; }
.text-gray { color: #555; }

/* Step3: 规格 */
.photo-preview-row { display: flex; gap: 12rpx; margin-bottom: 24rpx; flex-wrap: wrap; }
.preview-thumb { width: 130rpx; height: 130rpx; border-radius: 12rpx; }
.preview-more { width: 130rpx; height: 130rpx; border-radius: 12rpx; background: #f0f0f0; display: flex; align-items: center; justify-content: center; font-size: 28rpx; color: #999; font-weight: 700; }
.doc-summary { display: flex; align-items: center; gap: 20rpx; background: #f5f8ff; border-radius: 16rpx; padding: 20rpx; margin-bottom: 24rpx; }
.doc-icon-big { font-size: 60rpx; flex-shrink: 0; }
.doc-info { flex: 1; overflow: hidden; }
.doc-name { font-size: 26rpx; font-weight: 600; color: #333; display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.doc-mode { font-size: 22rpx; display: block; margin-top: 6rpx; }
.field-row { display: flex; align-items: center; justify-content: space-between; padding: 20rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.field-label { font-size: 28rpx; color: #555; font-weight: 600; }
.picker-val { font-size: 28rpx; color: #FF6B6B; font-weight: 600; }
.picker-arrow { font-size: 22rpx; color: #bbb; }
.count-input { text-align: right; font-size: 30rpx; color: #FF6B6B; font-weight: 700; width: 120rpx; border: none; background: transparent; }
.no-printer { font-size: 26rpx; color: #bbb; text-align: center; padding: 16rpx 0; }

/* Step4: 确认 */
.doc-confirm { text-align: center; padding: 20rpx 0 8rpx; }
.confirm-icon { font-size: 80rpx; display: block; }
.confirm-title { font-size: 28rpx; font-weight: 700; color: #333; margin-top: 8rpx; margin-bottom: 16rpx; }
.layout-preview { width: 100%; border-radius: 16rpx; margin-bottom: 20rpx; display: block; }
.spec-summary { background: #f8f8f8; border-radius: 16rpx; padding: 16rpx 20rpx; margin-bottom: 24rpx; }
.spec-row { display: flex; justify-content: space-between; align-items: center; padding: 10rpx 0; border-bottom: 1rpx solid #eee; }
.spec-row:last-child { border-bottom: none; }
.spec-key { font-size: 26rpx; color: #999; }
.spec-val { font-size: 26rpx; color: #333; font-weight: 600; }
.spec-filename { max-width: 340rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-size: 24rpx; }

/* Step5: 完成 */
.done-card { text-align: center; }
.done-icon { font-size: 100rpx; display: block; margin-bottom: 16rpx; }
.done-title { font-size: 36rpx; font-weight: 700; color: #333; margin-bottom: 32rpx; }
.status-row { display: flex; align-items: center; justify-content: space-between; padding: 20rpx; background: #f8f8f8; border-radius: 16rpx; margin-bottom: 16rpx; }
.status-label { font-size: 28rpx; color: #666; }
.status-badge { padding: 10rpx 24rpx; border-radius: 20rpx; font-size: 26rpx; font-weight: 700; }
.status-badge.pending { background: #fff3e0; color: #ff9800; }
.status-badge.printing { background: #e3f2fd; color: #2196f3; }
.status-badge.done { background: #e8f5e9; color: #4caf50; }
.job-id { font-size: 22rpx; color: #bbb; margin-bottom: 32rpx; word-break: break-all; }
