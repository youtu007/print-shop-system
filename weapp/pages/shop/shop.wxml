<view class="page">
  <view class="shop-section-title"><text class="shop-section-dot"></text><text>商城</text></view>

  <view wx:if="{{loading}}" class="grid">
    <view class="skeleton-card" wx:for="{{[1,2,3,4]}}" wx:key="*this">
      <view class="sk-img"></view>
      <view class="sk-line sk-name"></view>
      <view class="sk-line sk-desc"></view>
      <view class="sk-line sk-price"></view>
    </view>
  </view>

  <view wx:else class="grid">
    <view class="card" wx:for="{{products}}" wx:key="id">
      <view class="product-img-placeholder">
        <view class="css-icon css-icon-md icon-shop" style="color:rgba(255,107,107,0.4)"></view>
        <view wx:if="{{item.need_file}}" class="need-file-tag">需上传文件</view>
      </view>
      <text class="p-name">{{item.name}}</text>
      <text class="p-desc">{{item.description}}</text>
      <view class="p-bottom">
        <text class="p-price">¥{{item.price}}{{item.file_type === 'photo' ? '/版' : item.price_unit === 'per_page' ? '/张' : ''}}</text>
        <button class="add-btn" bindtap="tapAdd" data-idx="{{index}}">+</button>
      </view>
    </view>
  </view>

  <view wx:if="{{orderId}}" class="success-bar anim-slide-up" bindtap="viewOrder">下单成功，点击查看物流状态</view>

  <!-- 遮罩 -->
  <view wx:if="{{showActionSheet}}" class="mask" bindtap="closeSheet"></view>

  <!-- 底部面板 -->
  <view class="action-sheet {{showActionSheet ? 'action-sheet-show' : ''}}">
    <view class="sheet-handle"></view>
    <view class="sheet-product-info">
      <text class="sheet-name">{{selectedProduct.name}}</text>
      <text wx:if="{{!selectedProduct.need_file || !fileInfo}}" class="sheet-price">¥{{selectedProduct.price}}{{selectedProduct.file_type === 'photo' ? '/版' : selectedProduct.price_unit === 'per_page' ? '/张' : ''}}</text>
      <text wx:if="{{selectedProduct.need_file && fileInfo && selectedProduct.file_type !== 'photo'}}" class="sheet-price">¥{{computedPrice}} <text class="sheet-price-detail">（{{editPageCount}}张 × ¥{{selectedProduct.price}}/张）</text></text>
      <text wx:if="{{selectedProduct.need_file && fileInfo && selectedProduct.file_type === 'photo'}}" class="sheet-price">¥{{selectedProduct.price}}/版</text>
    </view>

    <!-- 需要上传文件的商品 -->
    <view wx:if="{{selectedProduct.need_file}}" class="file-section">
      <view wx:if="{{!fileInfo && !uploading}}" class="file-upload-btn" bindtap="chooseFile">
        <text class="upload-icon">+</text>
        <text class="upload-text">{{selectedProduct.file_type === 'photo' ? '从相册选择照片' : '从聊天记录选择文件'}}</text>
        <text class="upload-hint">{{selectedProduct.file_type === 'photo' ? '支持 JPG、PNG' : '支持 PDF、Word、图片'}}</text>
      </view>
      <view wx:if="{{uploading}}" class="file-uploading">上传识别中...</view>
      <view wx:if="{{fileInfo}}" class="file-info-card">
        <view class="file-info-row">
          <text class="file-name">{{fileInfo.file_name}}</text>
          <text class="file-reupload" bindtap="chooseFile">重新上传</text>
        </view>
        <view wx:if="{{selectedProduct.file_type !== 'photo'}}" class="file-page-row">
          <text>识别张数：</text>
          <input type="number" class="page-input" value="{{editPageCount}}" bindinput="onPageCountInput"/>
          <text class="page-unit">张</text>
        </view>
        <view wx:else class="file-page-row">
          <text class="photo-tip">照片已上传，打印为一版</text>
        </view>
      </view>
    </view>

    <button class="sheet-btn-primary" bindtap="doOrderNow">
      {{selectedProduct.need_file && fileInfo ? '立即下单 ¥' + computedPrice : '立即下单'}}
    </button>
    <button class="sheet-btn-cart" bindtap="addToCart">加入购物车</button>
    <button class="sheet-btn-cancel" bindtap="closeSheet">取消</button>
  </view>
</view>
