.need-file-tag{position:absolute;top:8rpx;right:8rpx;background:var(--color-primary);color:#fff;font-size:18rpx;padding:4rpx 12rpx;border-radius:var(--radius-pill);font-weight:600}
.file-section{margin-bottom:var(--space-lg)}
.file-upload-btn{border:2rpx dashed #ddd;border-radius:var(--radius-md);padding:40rpx;text-align:center;background:var(--color-bg-input)}
.upload-icon{font-size:60rpx;color:var(--color-primary);display:block}
.upload-text{display:block;font-size:var(--font-base);color:var(--color-text-primary);margin-top:10rpx}
.upload-hint{display:block;font-size:var(--font-xs);color:var(--color-text-tertiary);margin-top:6rpx}
.file-uploading{text-align:center;padding:40rpx;color:var(--color-text-tertiary);font-size:var(--font-base)}
.file-info-card{background:var(--color-bg-input);border-radius:var(--radius-md);padding:var(--space-lg)}
.file-info-row{display:flex;justify-content:space-between;align-items:center;margin-bottom:var(--space-md)}
.file-name{font-size:var(--font-sm);color:var(--color-text-primary);font-weight:600;flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.file-reupload{font-size:var(--font-sm);color:var(--color-primary);flex-shrink:0;margin-left:var(--space-md)}
.file-page-row{display:flex;align-items:center;font-size:var(--font-base)}
.page-input{width:100rpx;text-align:center;border-bottom:2rpx solid var(--color-primary);margin:0 10rpx;font-weight:700;font-size:var(--font-base)}
.page-unit{color:var(--color-text-tertiary)}
.sheet-price-detail{font-size:var(--font-xs);color:var(--color-text-tertiary);font-weight:400}
.photo-tip{font-size:var(--font-sm);color:var(--color-success);font-weight:600}