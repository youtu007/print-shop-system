e-md);background:linear-gradient(135deg,var(--color-primary),var(--color-primary-light));color:var(--color-text-white);border-radius:var(--radius-pill);width:56rpx;height:56rpx;font-size:40rpx;line-height:52rpx;text-align:center;border:none;padding:0;box-shadow:0 2rpx 8rpx rgba(255,107,107,0.3)}.success-bar{background:var(--color-success-bg);border-radius:var(--radius-md);padding:var(--space-lg);text-align:center;font-size:var(--font-base);font-weight:600;color:var(--color-success)}.mask{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.4);z-index:100}.action-sheet{position:fixed;left:0;right:0;bottom:0;background:#fff;border-radius:var(--radius-lg) var(--radius-lg) 0 0;padding:var(--space-xl) var(--space-xl) 60rpx;z-index:101;transform:translateY(100%);transition:transform 0.25s ease}.action-sheet-show{transform:translateY(0)}.sheet-handle{width:60rpx;height:6rpx;background:#ddd;border-radius:var(--radius-pill);margin:0 auto 20rpx}.sheet-product-info{padding:var(--space-md) 0 var(--space-xl);border-bottom:1rpx solid var(--color-border);margin-bottom:var(--space-lg)}.sheet-name{font-size:var(--font-md);font-weight:700;color:var(--color-text-primary);display:block;margin-bottom:var(--space-xs)}.sheet-price{font-size:34rpx;font-weight:800;color:var(--color-primary);display:block}.sheet-btn-primary{background:linear-gradient(135deg,var(--color-primary),var(--color-primary-light));color:var(--color-text-white);border-radius:var(--radius-md);padding:22rpx;font-size:var(--font-md);font-weight:700;border:none;width:100%;margin-bottom:var(--space-md);box-shadow:0 4rpx 16rpx rgba(255,107,107,0.3)}.sheet-btn-cart{background:var(--color-bg-card);color:var(--color-primary);border:2rpx solid var(--color-primary);border-radius:var(--radius-md);padding:22rpx;font-size:var(--font-md);font-weight:700;width:100%;margin-bottom:var(--space-md)}.sheet-btn-cart::after{border:none}.sheet-btn-cancel{background:var(--color-bg-input);color:var(--color-text-tertiary);border