.page{min-height:100vh;background:var(--color-bg-page);padding:var(--space-lg)}.page-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:var(--space-lg)}.page-title{font-size:var(--font-xl);font-weight:800}.btn-add{background:var(--color-primary);color:#fff;border:none;padding:12rpx 24rpx;border-radius:var(--radius-md);font-size:var(--font-sm)}.form-card{background:var(--color-bg-card);border-radius:var(--radius-lg);padding:var(--space-xl);margin-bottom:var(--space-lg);box-shadow:var(--shadow-sm)}.field{margin-bottom:var(--space-lg)}.field-label{display:block;font-size:var(--font-sm);color:var(--color-text-secondary);margin-bottom:var(--space-sm)}.input-base{background:var(--color-bg-input);border-radius:var(--radius-md);padding:var(--space-md);font-size:var(--font-base)}.picker-display{background:var(--color-bg-input);border-radius:var(--radius-md);padding:var(--space-md);font-size:var(--font-base)}.btn-submit{background:var(--color-primary);color:#fff;border:none;padding:var(--space-md);border-radius:var(--radius-md);font-size:var(--font-base);font-weight:600}.loading,.empty-tip{text-align:center;padding:120rpx;color:var(--color-text-tertiary)}.admin-list{display:flex;flex-direction:column;gap:var(--space-md)}.admin-card{background:var(--color-bg-card);border-radius:var(--radius-lg);padding:var(--space-lg);box-shadow:var(--shadow-sm);display:flex;align-items:center;gap:var(--space-md)}.admin-avatar{width:80rpx;height:80rpx;border-radius:50%;background:var(--color-primary);color:#fff;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:var(--font-lg)}.admin-info{flex:1}.admin-name{font-weight:600;font-size:var(--font-base)}.admin-role{font-size:var(--font-sm);color:var(--color-text-tertiary)}.admin-actions{display:flex;gap:var(--space-md)}.action-btn{font-size:var(--font-sm);color:var(--color-primary)}.action-btn.delete{color:var(--color-error)}.popup-mask{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.5);display:flex;align-items:center;justify-content:center;z-index:100}.popup{background:var(--color-bg-card);border-radius:var(--radius-lg);padding:var(--space-xl);width:80%;max-height:70vh}.popup-title{font-weight:700;font-size:var(--font-md);margin-bottom:var(--space-lg)}.printer-list{max-height:400rpx;overflow-y:auto}.printer-item{display:flex;align-items:center;gap:var(--space-md);padding:var(--space-md);border-bottom:1rpx solid var(--color-border)}.checkbox{width:40rpx;height:40rpx;border:2rpx solid var(--color-border);border-radius:var(--radius-sm)}.checkbox.checked{background:var(--color-primary);border-color:var(--color-primary)}