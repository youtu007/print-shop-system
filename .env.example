# 服务端口
PORT=3001

# JWT 密钥（必填，请使用随机长字符串）
JWT_SECRET=

# 数据库配置（MySQL，变量名须与 server/db.js 一致）
MYSQL_ADDRESS=localhost:3306
MYSQL_USERNAME=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=printer_demo

# 上传文件目录
UPLOADS_DIR=./uploads

# CORS 允许的源（逗号分隔）
CORS_ORIGINS=http://localhost:5174,http://localhost:3001

# 运行环境：development / production
NODE_ENV=development

# 超管默认密码（仅首次建库时使用）
ADMIN_PASSWORD=admin123

# 微信小程序 & 支付配置
WECHAT_APPID=
WECHAT_APPSECRET=
WECHAT_MCHID=
WECHAT_API_KEY=
WECHAT_SERIAL_NO=
WECHAT_NOTIFY_URL=https://your-domain.com/api/payment/notify
